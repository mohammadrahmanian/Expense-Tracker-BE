DATABASE_URL="postgresql://user:pass@db-url/name?schema=public"
JWT_SECRET="jwt_secret_token"
SENTRY_DSN="sentry-dsn"
CORS_ORIGIN="cors-origin-url"

# MCP server (Auth0 OAuth 2.1 resource server)
# AUTH0_DOMAIN: your Auth0 tenant, e.g. expensio.eu.auth0.com
# MCP_RESOURCE_URI: the public HTTPS URL of /mcp; must equal the Auth0 API identifier
# MCP_ENABLED: set to "false" to skip MCP plugin registration entirely
AUTH0_DOMAIN="your-tenant.eu.auth0.com"
MCP_RESOURCE_URI="https://api.example.com/mcp"
MCP_ENABLED="true"
